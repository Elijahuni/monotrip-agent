EXPO_PUBLIC_API_URL=http://localhost:8000

# ── Google OAuth ───────────────────────────────────────────────────────────────
# Google Cloud Console → API 및 서비스 → 사용자 인증 정보 → OAuth 2.0 클라이언트 ID
# 필요한 앱 유형: 웹(audience 검증), iOS, Android 각각 생성
# 활성화 순서:
#   1. console.cloud.google.com → 프로젝트 생성
#   2. OAuth 동의 화면 구성 (앱 이름, 이메일, 범위: email, profile, openid)
#   3. 사용자 인증 정보 → OAuth 2.0 클라이언트 ID 3개 생성
#      - 웹 애플리케이션 (백엔드 audience 검증용 — 리다이렉트 URI 불필요)
#      - iOS (Bundle ID: 백엔드 GOOGLE_IOS_CLIENT_ID와 동일 값)
#      - Android (패키지명 + SHA-1 지문 필요)
#   4. 아래 값 입력 후 백엔드 .env의 GOOGLE_CLIENT_ID 등도 동일하게 입력
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=     # 웹 클라이언트 ID (백엔드 검증 기준)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=     # iOS 클라이언트 ID
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID= # Android 클라이언트 ID

# ── EAS 프로젝트 ───────────────────────────────────────────────────────────────
# https://expo.dev → 프로젝트 → Project ID
# 서버 사이드 푸시 알림 사용 시 필수. 없으면 서버 등록 건너뜀 (로컬 알림은 동작).
EXPO_PUBLIC_EAS_PROJECT_ID=

# ── Sentry (에러 모니터링) ─────────────────────────────────────────────────────
# https://sentry.io → 프로젝트 생성 후 DSN 복사
# 비어있으면 lib/sentry.ts의 fallback DSN 사용. 프로덕션에서만 자동 전송.
EXPO_PUBLIC_SENTRY_DSN=

# DEV 빌드에서도 Sentry로 이벤트 전송하고 싶을 때만 1로 설정 (자체 테스트용)
EXPO_PUBLIC_SENTRY_FORCE_ENABLE=

# 앱 버전 (Sentry release 태그)
EXPO_PUBLIC_APP_VERSION=1.0.0
