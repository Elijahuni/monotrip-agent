EXPO_PUBLIC_API_URL=http://localhost:8000

# EAS 프로젝트 ID — https://expo.dev → 프로젝트 → Project ID
# 서버 사이드 푸시 알림 사용 시 필수. 없으면 서버 등록 건너뜀 (로컬 알림은 동작).
EXPO_PUBLIC_EAS_PROJECT_ID=

# Sentry (에러 모니터링) — https://sentry.io → 프로젝트 생성 후 DSN 복사
# 비어있으면 lib/sentry.ts의 fallback DSN 사용. 프로덕션에서만 자동 전송.
EXPO_PUBLIC_SENTRY_DSN=

# DEV 빌드에서도 Sentry로 이벤트 전송하고 싶을 때만 1로 설정 (자체 테스트용)
EXPO_PUBLIC_SENTRY_FORCE_ENABLE=

# 앱 버전 (Sentry release 태그)
EXPO_PUBLIC_APP_VERSION=1.0.0
