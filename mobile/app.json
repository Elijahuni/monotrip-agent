{
  "expo": {
    "name": "모노트립",
    "slug": "monotrip",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "monotrip",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "LSApplicationQueriesSchemes": [
          "instagram",
          "comgooglemaps",
          "kakaokompassauth",
          "kakaolink",
          "kakaotalk",
          "instagram",
          "comgooglemaps",
          "kakaokompassauth",
          "kakaolink",
          "kakaotalk"
        ],
        "CFBundleURLTypes": [
          {
            "CFBundleTypeRole": "Editor",
            "CFBundleURLSchemes": [
              "kakao38a4188dd9eba28696a7e70be08cdbc1"
            ]
          }
        ]
      },
      "bundleIdentifier": "com.anonymous.monotrip"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.monotrip"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-sqlite",
      "@react-native-community/datetimepicker",
      [
        "@react-native-seoul/kakao-login",
        {
          "kakaoAppKey": "38a4188dd9eba28696a7e70be08cdbc1",
          "kotlinVersion": "1.9.0",
          "overrideKakaoSDKVersion": "2.22.7"
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "monotrip-mobile",
          "organization": "monotrip"
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
