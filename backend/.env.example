# ============================================================
# Triple Clone Backend — Environment Variables
# 실제 값을 .env 파일에 작성하고, .env는 절대 commit 하지 마세요.
# ============================================================

# ---------- Database (PostgreSQL 16 + pgvector) ----------
# 형식: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/triple"

# ---------- AI (Google Gemini) ----------
# 발급: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""

# ---------- Places (Google Places API New) ----------
# 발급: https://console.cloud.google.com/apis/credentials → Places API (New) 활성화
GOOGLE_PLACES_API_KEY=""

# ---------- Auth (JWT) ----------
# 랜덤 시크릿 생성: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=""
JWT_ALGORITHM="HS256"
JWT_EXPIRE_MINUTES=43200

# ---------- App Settings ----------
APP_ENV="development"  # development | staging | production
LOG_LEVEL="INFO"       # DEBUG | INFO | WARNING | ERROR
