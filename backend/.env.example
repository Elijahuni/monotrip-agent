# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/triple

# AI
GEMINI_API_KEY=

# Google APIs (장소 검색)
GOOGLE_PLACES_API_KEY=

# JWT
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=43200

# App
APP_ENV=development
LOG_LEVEL=INFO

# CORS — 콤마 구분 (예: https://app.monotrip.com,exp://...) 또는 "*"
CORS_ORIGINS=*

# 푸시 알림 스케줄러 — APP_ENV=test 이면 자동으로 비활성화.
# Railway 등 멀티 인스턴스 배포 시 한 인스턴스만 실행하도록 조정 권장.
# (기본: APP_ENV=production이면 활성화)

# Sentry (에러 모니터링) — https://sentry.io → 프로젝트 생성 후 DSN 복사
# 비어있으면 Sentry 비활성화 (로컬/개발 환경에서 설정 불필요)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Google OAuth ───────────────────────────────────────────────────────────────
# 모바일 .env.example의 EXPO_PUBLIC_GOOGLE_* 와 동일한 값을 여기에도 입력.
# 비어있으면 audience 검증 생략 (개발 환경에서 편의상 허용, 프로덕션은 필수 입력).
GOOGLE_CLIENT_ID=             # 웹 클라이언트 ID (id_token audience 검증 기준)
GOOGLE_IOS_CLIENT_ID=         # iOS 클라이언트 ID
GOOGLE_ANDROID_CLIENT_ID=     # Android 클라이언트 ID

# Apple Sign In
# Apple Developer → Certificates, Identifiers & Profiles → App ID → Bundle ID
# (예: com.yourcompany.triple). 비어있으면 audience 검증 생략 (개발 환경).
APPLE_CLIENT_ID=

# ── 메타서치 어필리에이트 API ──────────────────────────────────────────────────
# 비어있으면 Mock 가격(화면에 "참고용" 배지 표시)으로 폴백. 기능은 정상 동작.

# Skyscanner (RapidAPI) — 항공권 실연동
#   발급: https://rapidapi.com/skyscanner/api/skyscanner50 → Subscribe (무료 500회/월)
#   복사 위치: RapidAPI 헤더 "X-RapidAPI-Key"
RAPIDAPI_KEY=

# Booking.com Affiliate — 호텔 실연동
#   발급: https://www.booking.com/affiliate-program/ → 파트너 신청 → Demand API 승인
#   승인까지 영업일 3~5일 소요. 대안: Agoda Affiliate (즉시 발급)
BOOKING_AFFILIATE_ID=
BOOKING_AFFILIATE_SECRET=

# Cloudflare R2 (이미지 저장소) — https://dash.cloudflare.com → R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=monotrip-images
# 퍼블릭 URL (R2 → Bucket → Public R2.dev URL or custom domain)
R2_PUBLIC_URL=
