# ============================================================
# Triple Clone Backend — Environment Variables
# 실제 값을 .env 파일에 작성하고, .env는 절대 commit 하지 마세요.
# ============================================================

# ---------- Database (PostgreSQL 16 + pgvector) ----------
# 형식: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/triple"

# ---------- AI (Google Gemini) ----------
# 발급: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""

# ---------- App Settings ----------
APP_ENV="development"  # development | staging | production
LOG_LEVEL="INFO"       # DEBUG | INFO | WARNING | ERROR
