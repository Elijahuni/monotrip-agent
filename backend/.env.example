# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/triple

# AI
GEMINI_API_KEY=

# Google APIs (장소 검색)
GOOGLE_PLACES_API_KEY=

# JWT
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=43200

# App
APP_ENV=development
LOG_LEVEL=INFO

# CORS — 콤마 구분 (예: https://app.monotrip.com,exp://...) 또는 "*"
CORS_ORIGINS=*

# 푸시 알림 스케줄러 — APP_ENV=test 이면 자동으로 비활성화.
# Railway 등 멀티 인스턴스 배포 시 한 인스턴스만 실행하도록 조정 권장.
# (기본: APP_ENV=production이면 활성화)

# Sentry (에러 모니터링) — https://sentry.io → 프로젝트 생성 후 DSN 복사
# 비어있으면 Sentry 비활성화 (로컬/개발 환경에서 설정 불필요)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# 메타서치 어필리에이트 API
# ── Skyscanner (RapidAPI) ──────────────────────────────────────────────────────
# https://rapidapi.com/skyscanner/api/skyscanner50 → "Subscribe" → 키 복사
# 무료 플랜: 월 500 요청. 비어있으면 Mock 가격(참고용)으로 폴백.
RAPIDAPI_KEY=

# ── Booking.com Affiliate ──────────────────────────────────────────────────────
# https://www.booking.com/affiliate-program/ → 파트너 신청 → Demand API 승인 후 발급
# 비어있으면 Mock 가격(참고용)으로 폴백.
BOOKING_AFFILIATE_ID=
BOOKING_AFFILIATE_SECRET=

# Cloudflare R2 (이미지 저장소) — https://dash.cloudflare.com → R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=monotrip-images
# 퍼블릭 URL (R2 → Bucket → Public R2.dev URL or custom domain)
R2_PUBLIC_URL=
